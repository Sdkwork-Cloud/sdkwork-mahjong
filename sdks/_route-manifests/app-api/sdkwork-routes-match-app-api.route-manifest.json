        "apiAuthority": "sdkwork-mahjong-app-api"
      },
      "source": {
        "file": "apis/app-api/game/mahjong-app-api.openapi.json"
      }
    },
    {
      "method": "GET",
      "path": "/app/v3/api/mahjong/matches/{matchId}",
      "operationId": "mahjong.match.retrieve",
      "tags": [
        "mahjong"
      ],
      "requestContext": "WebRequestContext",
