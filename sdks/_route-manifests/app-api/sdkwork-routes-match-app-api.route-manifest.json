        "mahjong"
      ],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": {
        "mode": "dual-token",
        "required": true,
        "tenantScope": "tenant",
        "dataScope": "organization"
      },
      "handler": {
        "module": "crate",
        "name": "mahjong_match_list"
      },
      "schemas": {
        "request": null,
        "response": "SdkWorkMatchPageResponse",
