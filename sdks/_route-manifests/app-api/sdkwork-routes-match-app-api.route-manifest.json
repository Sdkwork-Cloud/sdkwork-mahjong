      "auth": {
        "mode": "dual-token",
        "required": true,
        "tenantScope": "tenant",
        "dataScope": "organization"
      },
      "handler": {
        "module": "crate",
        "name": "mahjong_match_retrieve"
      },
      "schemas": {
        "request": null,
        "response": "SdkWorkMatchResourceResponse",
        "problem": "ProblemDetail"
      },
      "ownership": {
        "owner": "sdkwork-mahjong",
        "apiAuthority": "sdkwork-mahjong-app-api"
      },
      "source": {
        "file": "apis/app-api/game/mahjong-app-api.openapi.json"
      }
    }
  ]
}
