{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-match-app-api",
  "surface": "app-api",
  "owner": "sdkwork-mahjong",
  "domain": "game",
  "capability": "match",
  "apiAuthority": "sdkwork-mahjong-app-api",
  "sdkFamily": "sdkwork-mahjong-app-sdk",
  "prefix": "/app/v3/api",
  "source": {
    "crateRoot": "crates/sdkwork-routes-match-app-api",
    "crateImport": "sdkwork_routes_match_app_api",
    "openapiAuthority": "apis/app-api/game/mahjong-app-api.openapi.json"
  },
  "routes": [
